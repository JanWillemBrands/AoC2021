// These are included in XID_Continue
//identifierCharacter = Digit 0 through 9
//identifierCharacter = U+0300–U+036F, U+1DC0–U+1DFF, U+20D0–U+20FF, or U+FE20–U+FE2F
//identifierCharacter = identifierHead .
//identifierCharacters = identifierCharacter identifierCharacters? .

//implicitParameterName = "$" decimalDigits .
//propertyWrapperProjection = "$" identifierCharacters .


// REGULAR EXPRESSIONS


// ──────────────────────────────────────────────────────────────────────────
// Plain slash-regex literal — parser-level CFG.
//
// Replaces the older scanner-level terminal (kept commented below for reference).
// The CFG enforces delimiter balance inside the body, so over-claim cases like
// `(/E.e).foo(/0)` fail at parse time — the stray `)` is not a regexAtom and
// can only appear inside a balanced regexGroup. The `>s<` annotations forbid
// whitespace adjacent to either `/`, which subsumes the empty-regex and
// leading/trailing-space rejections the old scanner regex performed inline.
//
// Operator overlap: atom characters like `^`, `*`, `+`, etc. reach the regex
// body via the existing operator terminals (`operatorHead`, `operatorSpecial`)
// rather than via a competing anonymous regex terminal, so `/^/` parses cleanly.
//
// See `Regex CFG Discussion.md` for the design rationale.
// ──────────────────────────────────────────────────────────────────────────

regexEscape          - /\\[^\r\n]/ .
regexNonOperatorAtom - /[^\/\\\[\]\(\)\r\n\+\-\*%&\|\^~<>=!\?\.#;:,]/ .
regexClassAtom       - /[^\\\]\r\n]/ .
// A single operator character inside a regex body. A REGEX terminal (not the
// shared operator literals) so it is exempt from operatorToken maximal munch —
// otherwise `/^/`'s `^` would be eaten as the operator `^/`, and `/(.*?)/`'s
// `*?` would fuse. Excludes `/` (the regex delimiter, matched by regexSlash).
regexOperatorChar    - /[-+*%|^~<>=!?&.]/ .

regexSlash - /\// .
plainRegularExpressionLiteral = regexSlash >s< regexBody >s< regexSlash .   // regexSlash is a REGEX terminal → exempt from operatorToken maximal munch, so `/^/`'s opening `/` isn't eaten as the operator `/^`

regexBody       = regexItem | regexItem regexBody .
regexItem       = regexEscape | regexCharacterClass | regexGroup | regexAtom .
regexGroup      = "(" regexBody ")" .
regexCharacterClass = "[" regexClassBody "]" .
regexClassBody  = regexClassItem | regexClassItem regexClassBody .   // Swift forbids []
regexClassItem  = regexEscape | regexClassAtom .

// Operator-overlap-safe atom reachable through existing terminals.
regexAtom       = regexNonOperatorAtom
                | regexOperatorChar
                | "#" | ":" | ";" | "," .

// ── Previous scanner-level terminal (kept for quick revert if needed) ──
//plainRegularExpressionLiteral       - /\/(?![\s*])(?:[^\/\\\n]|\\.)*(?:[^\/\\\n\s]|\\.)\// .
//    --1( "true" "false" "nil" "self" "Self" "super" "Any"
//         "func" "operator"
//         rawIdentifier escapedIdentifier implicitParameterName propertyWrapperProjection
//         binaryLiteral octalLiteral decimalNumber hexadecimalLiteral
//         decimalFloatingPointLiteral hexadecimalFloatingPointLiteral
//         plainRegularExpressionLiteral extendedRegularExpressionLiteral
//         ")" "]" "}" ">"
//         "!"
//         "->" "..." "." "@" )
//    ++2("try"), ++1("!")

extendedRegularExpressionLiteral    - /(#+)\/(?:[^\/]|\/(?!\1))*?\/\1/ .   // backref: closing #s must equal opening; no escapes in extended regex, `/` is body content, only `/#…` closes
    --1( "true" "false" "nil" "self" "Self" "super" "Any"
         "func" "operator"
         rawIdentifier escapedIdentifier implicitParameterName propertyWrapperProjection
         binaryLiteral octalLiteral decimalNumber hexadecimalLiteral
         decimalFloatingPointLiteral hexadecimalFloatingPointLiteral
         plainRegularExpressionLiteral extendedRegularExpressionLiteral
         ")" "]" "}" ">"
         "!"
         "->" "..." "." "@" )

regularExpressionLiteral = plainRegularExpressionLiteral | extendedRegularExpressionLiteral .

//regularExpressionLiteral = regularExpressionLiteralOpeningDelimiter regularExpression regularExpressionLiteralClosingDelimiter .
//regularExpression = Any regular expression
//regularExpressionLiteralOpeningDelimiter = extendedRegularExpressionLiteralDelimiter? "/" .
//regularExpressionLiteralClosingDelimiter = "/" extendedRegularExpressionLiteralDelimiter? .
//extendedRegularExpressionLiteralDelimiter = "#" extendedRegularExpressionLiteralDelimiter? .


// STRINGS

stringLiteral = staticStringLiteral | interpolatedStringLiteral .

singleLineStringLiteral         - /"(?:[^"\\\n\r]|\\u\{[0-9a-fA-F]+\}|\\[0\\tnr"']|\\(?!\().)*?"/ . // start with " end with " same line, no \(
extendedSinglelineStringLiteral - /(#+)"(?:[^"\n\r]|"(?!\1))*?"\1/ .   // backref: closing #s must equal opening

multilineStringLiteral          - /"""(?![\s\S]*\\\()(?:[^"\\]|\\[\s\S]|"(?!""))*"""/ . // start """ end """; body's `\<x>` uses `[\s\S]` so `\<NL>` (multiline line-continuation per swift-syntax Cursor.swift:1766) is body content; lookahead uses `[\s\S]` so it crosses newlines
extendedMultilineStringLiteral  - /(#+)"""(?s:.)*?"""\1/ .             // backref: closing #s must equal opening

staticStringLiteral             = singleLineStringLiteral
                                | extendedSinglelineStringLiteral
                                | multilineStringLiteral
                                | extendedMultilineStringLiteral .
                                
// Under LCNP these terminals are queried per-slot, so the spurious matches that
// would happen outside an interpolated-string context are never asked for.
interpolatedStringLiteralHead   - /"(?:[^"\\\n\r]|\\u\{[0-9a-fA-F]+\}|\\[0\\tnr"']|\\.)*?\\\(/ .     // start with ", end with \( same line

interpolatedStringLiteralPart   - /\)(?:[^"\\\n\r]|\\u\{[0-9a-fA-F]+\}|\\[0\\tnr"']|\\.)*?\\\(/ .    // start with ), end with \( same line

interpolatedStringLiteralTail   - /\)(?:[^"\\\n\r]|\\u\{[0-9a-fA-F]+\}|\\[0\\tnr"']|\\(?!\().)*?"/ . // start with ), end with " same line, no \(

// Multiline variants — structurally symmetric to the single-line trio above.
// Differences: open is """ (Head), close is """ (Tail); content alternation adds `"(?!"")` so a single `"`
// (not followed by `""`) is valid body content — the only multiline-specific feature.
// Multiline body's catch-all backslash uses `[\s\S]` (not `.`) so `\<NL>` line-continuation per swift-syntax Cursor.swift:1766 is body content.
multilineInterpolatedStringLiteralHead - /"""(?:[^"\\]|\\u\{[0-9a-fA-F]+\}|\\[0\\tnr"']|\\[\s\S]|"(?!""))*?\\\(/ .  // start with """, end with \(

multilineInterpolatedStringLiteralPart - /\)(?:[^"\\]|\\u\{[0-9a-fA-F]+\}|\\[0\\tnr"']|\\[\s\S]|"(?!""))*?\\\(/ .   // start with ),    end with \(

multilineInterpolatedStringLiteralTail - /\)(?:[^"\\]|\\u\{[0-9a-fA-F]+\}|\\(?!\()[\s\S]|"(?!""))*?"""/ . // start with ), end with """; body's `\<x>` (x ≠ `(`) uses [\s\S] so `\<NL>` is body content

interpolatedStringLiteral       = interpolatedStringLiteralHead
                                  functionCallArgumentList { interpolatedStringLiteralPart functionCallArgumentList }
                                  interpolatedStringLiteralTail .
interpolatedStringLiteral       = multilineInterpolatedStringLiteralHead
                                  functionCallArgumentList { multilineInterpolatedStringLiteralPart functionCallArgumentList }
                                  multilineInterpolatedStringLiteralTail .



//stringLiteralOpeningDelimiter = extendedStringLiteralDelimiter? "\"" .
//stringLiteralClosingDelimiter = "\"" extendedStringLiteralDelimiter? .

