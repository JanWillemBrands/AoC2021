// SWIFT 6.3 GRAMMAR

// swift-syntax parseSourceFile (TopLevel.swift:47) consumes an optional leading `.shebang`
// (`#!…` interpreter line) before the top-level items. `shebang?` appears only here, in the
// root production at offset 0, and `#!` is not valid Swift anywhere else, so it can only match
// a true leading shebang. `.*` stops at end of line; the newline is then whitespace trivia.
// `shebang` must be defined before it is referenced (named terminals require prior definition).
shebang - /#!.*/ .
topLevelDeclaration = shebang? statements? .

// WHITESPACE AND COMMENT

whitespace : /\s+/.                                                     // simplified

//whitespace = whitespaceItem whitespace? .
//whitespaceItem = lineBreak .
//whitespaceItem = inlineSpace .
//whitespaceItem = comment .
//whitespaceItem = multilineComment .
//whitespaceItem = U+0000, U+000B, or U+000C.                           // NULL or \0 or \u{0000}, VERTICAL TAB or \u{000B}, or FORM FEED or \u{000C}

//lineBreak = U+000A                                                    // NEWLINE or \n or \u{000A}
//lineBreak = U+000D                                                    // CARRIAGE RETURN or \r or \u{000D}
//lineBreak = U+000D followed by U+000A

//inlineSpaces = inlineSpace inlineSpaces? .
//inlineSpace = U+0009 or U+0020                                        // HORIZONTAL TAB or \t or \u{0009}, SPACE or \u{0020}

comment : /\/\/.*\r?\n?/ .
//comment = "//" commentText lineBreak .
//commentText = commentTextItem commentText? .
//commentTextItem = Any Unicode scalar value except U+000A or U+000D

// SCANNER MODE ANNOTATIONS TO HANDLE NESTED COMMENTS

// Nested multiline comment — Phase E Step 2 (Jun 13, 2026).
// Replaces three scanner-mode terminals + six `===` annotations with a single
// `=:` non-terminal whose recursive body lets the full GLL machinery handle
// nesting. Recognised as trivia during `OnDemandLiteralLexer.skipTrivia`.
multilineComment =: "/*" { /(?s)(?:[^*\/]|\*(?!\/)|\/(?!\*))+/ | multilineComment } "*/" .

//multilineComment = "/*" multilineCommentText "*/" .
//multilineCommentText = multilineCommentTextItem multilineCommentText? .
//multilineCommentTextItem = multilineComment .
//multilineCommentTextItem = commentTextItem .
//multilineCommentTextItem = Any Unicode scalar value except "/*" or "*/"


//IDENTIFIERS

// ACTIVE: Unicode-property identifier terminal. \p{So} includes emoji. Standalone
// '_' produces a Schrödinger token: '_' ~ rawIdentifier.
//rawIdentifier               - /[\p{XID_Start}_\p{So}][\p{XID_Continue}\p{So}]*/ .

@lexicalClass rawIdentifier - /[\p{XID_Start}\p{So}][\p{XID_Continue}\p{So}]*|_[\p{XID_Continue}\p{So}]+/ . // \p{So} includes emoji; @lexicalClass = keywords are longest-matched against this (maximal munch)
//
// COMMENTED ALTERNATIVE — explicit N1518 ranges, verbatim from swift-syntax
// `isValidIdentifierStartCodePoint`/`isValidIdentifierContinuationCodePoint`
// (SwiftParser/Lexer/UnicodeScalarExtensions.swift:14-94). This is the *faithful*
// definition (disjoint from the operator ranges, no \p{So} spill), BUT it does NOT
// COMPILE under Swift `Regex`: a canonically-decomposing scalar (e.g. U+F900 CJK
// compat ideograph) is rejected as a character-class range BOUND, and variation
// selectors (U+180B-180D, U+FE00-FE0F) fatal at *match* time under grapheme
// semantics, with no run-time scalar-semantics escape (`(?u)` unsupported). Kept
// here for when the terminal engine gains scalar-semantic matching (see TODO #8 /
// the code-point-class primitive proposal). START = CONTINUE minus the four
// "disallowed-initially" combining ranges (0300-036F,1DC0-1DFF,20D0-20FF,FE20-FE2F);
// sole start-overlap with operators (U+3021-302F) resolves as identifier per
// swift-syntax dispatch order (Cursor.swift:1056-1061).
//rawIdentifier - /[A-Za-z_\u{00A8}\u{00AA}\u{00AD}\u{00AF}\u{00B2}-\u{00B5}\u{00B7}-\u{00BA}\u{00BC}-\u{00BE}\u{00C0}-\u{00D6}\u{00D8}-\u{00F6}\u{00F8}-\u{02FF}\u{0370}-\u{167F}\u{1681}-\u{180D}\u{180F}-\u{1DBF}\u{1E00}-\u{1FFF}\u{200B}-\u{200D}\u{202A}-\u{202E}\u{203F}-\u{2040}\u{2054}\u{2060}-\u{20CF}\u{2100}-\u{218F}\u{2460}-\u{24FF}\u{2776}-\u{2793}\u{2C00}-\u{2DFF}\u{2E80}-\u{2FFF}\u{3004}-\u{3007}\u{3021}-\u{302F}\u{3031}-\u{D7FF}\u{F900}-\u{FD3D}\u{FD40}-\u{FDCF}\u{FDF0}-\u{FE1F}\u{FE30}-\u{FE44}\u{FE47}-\u{FFF8}\u{10000}-\u{1FFFD}\u{20000}-\u{2FFFD}\u{30000}-\u{3FFFD}\u{40000}-\u{4FFFD}\u{50000}-\u{5FFFD}\u{60000}-\u{6FFFD}\u{70000}-\u{7FFFD}\u{80000}-\u{8FFFD}\u{90000}-\u{9FFFD}\u{A0000}-\u{AFFFD}\u{B0000}-\u{BFFFD}\u{C0000}-\u{CFFFD}\u{D0000}-\u{DFFFD}\u{E0000}-\u{EFFFD}][A-Za-z0-9_\u{00A8}\u{00AA}\u{00AD}\u{00AF}\u{00B2}-\u{00B5}\u{00B7}-\u{00BA}\u{00BC}-\u{00BE}\u{00C0}-\u{00D6}\u{00D8}-\u{00F6}\u{00F8}-\u{167F}\u{1681}-\u{180D}\u{180F}-\u{1FFF}\u{200B}-\u{200D}\u{202A}-\u{202E}\u{203F}-\u{2040}\u{2054}\u{2060}-\u{218F}\u{2460}-\u{24FF}\u{2776}-\u{2793}\u{2C00}-\u{2DFF}\u{2E80}-\u{2FFF}\u{3004}-\u{3007}\u{3021}-\u{302F}\u{3031}-\u{D7FF}\u{F900}-\u{FD3D}\u{FD40}-\u{FDCF}\u{FDF0}-\u{FE44}\u{FE47}-\u{FFF8}\u{10000}-\u{1FFFD}\u{20000}-\u{2FFFD}\u{30000}-\u{3FFFD}\u{40000}-\u{4FFFD}\u{50000}-\u{5FFFD}\u{60000}-\u{6FFFD}\u{70000}-\u{7FFFD}\u{80000}-\u{8FFFD}\u{90000}-\u{9FFFD}\u{A0000}-\u{AFFFD}\u{B0000}-\u{BFFFD}\u{C0000}-\u{CFFFD}\u{D0000}-\u{DFFFD}\u{E0000}-\u{EFFFD}]*/ .
                                                                        
escapedIdentifier           - /`[^`\n\r\u{000B}\u{000C}\u{0085}\u{2028}\u{2029}]+`/ .       // 6.2 allows ` hello world `

implicitParameterName       - /\$[0-9]+/ .
propertyWrapperProjection   - /\$[0-9]*[\p{XID_Continue}--[0-9]]\p{XID_Continue}*/ .   // `$` + XID_Continue chars with at least ONE non-digit: swift-syntax lexes `$0`/`$12` (all digits) as a dollar-identifier (implicitParameterName) and only `$café`/`$1a` (has a non-digit) as an .identifier. Requiring a non-digit removes the `$0` overlap with implicitParameterName.



// all Swift 6.3 literals that start with a letter
//  "Any" "Linux" "Protocol" "Self" "Type" "Windows" "actor" "alpha" "any" "arch" "arm" "arm64" "as" "assignment" "associatedtype" "associativity" "async" "await" "blue" "borrowing" "break" "canImport" "case" "catch" "class" "compiler" "consuming" "continue" "convenience" "default" "defer" "deinit" "didSet" "discard" "do" "dynamic" "each" "else" "enum" "extension" "fallthrough" "false" "file" "fileprivate" "final" "for" "func" "get" "getter" "green" "guard" "higherThan" "i386" "iOS" "iOSApplicationExtension" "if" "import" "in" "indirect" "infix" "init" "inout" "internal" "is" "isolated" "lazy" "left" "let" "line" "lowerThan" "macCatalyst" "macCatalystApplicationExtension" "macOS" "macOSApplicationExtension" "macro" "move" "mutating" "nil" "none" "nonisolated" "nonmutating" "open" "operator" "optional" "os" "override" "package" "postfix" "precedencegroup" "prefix" "private" "protocol" "public" "red" "repeat" "required" "resourceName" "rethrows" "return" "right" "safe" "self" "set" "setter" "simulator" "some" "static" "struct" "subscript" "super" "swift" "switch" "targetEnvironment" "throw" "throws" "true" "try" "tvOS" "tvOSApplicationExtension" "typealias" "unowned" "unsafe" "var" "visionOS" "visionOSApplicationExtension" "wasm32" "watchOS" "watchOSApplicationExtension" "weak" "where" "while" "willSet" "x86_64" "yield"

// all Swift 6.3 literals that start with #
//  "#" "#available" "#colorLiteral" "#else" "#elseif" "#endif" "#error" "#fileLiteral" "#if" "#imageLiteral" "#keyPath" "#selector" "#sourceLocation" "#unavailable" "#warning"

// all remaining Swift 6.3 literals (punctuation and operators)
//  "!" "%" "&" "&&" "(" ")" "*" "*/" "+" "," "-" "->" "." "..." "//" "/*" ":" ";" "<" "=" "==" ">" ">=" "?" "[" "\\" "]" "^" "_" "{" "|" "||" "}" "~"

// all Swift 'hard' keywords that CANNOT be used as identifiers, except as augumentName
//  "Any" "as" "associatedtype" "await" "break" "case" "catch" "class" "continue" "default" "defer" "deinit" "do" "else" "enum" "extension" "fallthrough" "false" "fileprivate" "for" "func" "guard" "if" "import" "in" "init" "inout" "internal" "is" "let" "nil" "open" "operator" "precedencegroup" "private" "protocol" "public" "repeat" "rethrows" "return" "self" "Self" "static" "struct" "subscript" "super" "switch" "throw" "throws" "true" "try" "typealias" "var" "where" "while"

// all Swift contextual keywords that CAN be used as identifiers, except in specific locations
// "actor" "associativity" "async" "assignment" "borrowing" "consuming" "convenience" "didSet" "dynamic" "final" "get" "higherThan" "indirect" "infix" "isolated" "lazy" "left" "lowerThan" "mutating" "none" "nonisolated" "nonmutating" "optional" "override" "package" "postfix" "prefix" "Protocol" "required" "right" "set" "some" "Type" "unowned" "weak" "willSet" "yield"

// Most Swift identifiers exclude the hard reserved keywords (contextual keywords like 'borrowing', 'consuming', 'nonisolated', 'actor', 'isolated' can be identifiers per SE-0377/SE-0306/SE-0313)
// `propertyWrapperProjection` ($café-style) IS an identifier — swift-syntax lexes `$` + non-all-digit chars as `.identifier`
// (Cursor.swift:2343-2346). `implicitParameterName` ($0/$1) is NOT an identifier — swift-syntax lexes it as
// `.dollarIdentifier` and parses it as a distinct primary expression form via `parseAnonymousClosureArgument`
// (Expressions.swift:1348). It appears as its own `primaryExpression` alternate below.
identifier  = rawIdentifier ---("Any" "as" "associatedtype" "await" "break" "case" "catch" "class" "continue" "default" "defer" "deinit" "do" "else" "enum" "extension" "fallthrough" "false" "fileprivate" "for" "func" "guard" "if" "import" "in" "init" "inout" "internal" "is" "let" "nil" "open" "operator" "precedencegroup" "private" "protocol" "public" "repeat" "rethrows" "return" "self" "Self" "static" "struct" "subscript" "super" "switch" "throw" "throws" "true" "try" "typealias" "var" "where" "while")
            | escapedIdentifier
            | propertyWrapperProjection .

// Swift allows keywords as argument labels and as member names, just a few keywords are excluded for legacy reasons.
// `propertyWrapperProjection` ($café-style) is included because swift-syntax lexes `$` + non-all-digit chars
// as `.identifier` (Cursor.swift:2343-2346), making it eligible wherever an identifier is — including member
// names like `S().$café`. `implicitParameterName` ($0) is deliberately omitted: swift-syntax lexes that as
// `.dollarIdentifier` and parses it via `parseAnonymousClosureArgument` (Expressions.swift:1348), not via
// identifier — so it should NOT be a valid member name.
softIdentifier  = rawIdentifier ---("let" "var" "inout")
                | escapedIdentifier
                | propertyWrapperProjection .

identifierList = identifier | identifier "," identifierList .

// MODULE SELECTOR — SE-0491 (accepted). A referenced name may be prefixed by `Module::` to
// disambiguate which module it comes from. swift-syntax parseModuleSelectorIfPresent (Names.swift:125)
// consumes `name ::` before the actual name in both expression and type positions. `::` is a new
// token used nowhere else, so threading `moduleSelector?` through name positions adds no ambiguity.
moduleSelector = identifier "::" .

