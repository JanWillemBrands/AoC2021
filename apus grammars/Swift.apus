      @lifetime(borrow ne1, n2)
      func derive4(ne1: NE, ne2: NE) -> NE { ne1 }

      @lifetime(neOut: ne)
      func derive5(ne: NE, neOut: inout NE) -> NE { neOut = ne }

      @lifetime(neOut: borrow ne)
      func derive6(ne: borrowing NE, neOut: inout NE) -> NE { neOut = ne }
      
