^^^
      switch 42 {
      case borrowing + borrowing: // parses as expr pattern
        break
      }
      
^^^
      switch 42 {
      case borrowing(let borrowing): // parses as let binding named 'borrowing' inside a case pattern named 'borrowing'
        break
      }
      
^^^
      switch 42 {
      case {}(borrowing + borrowing): // parses as expr pattern
