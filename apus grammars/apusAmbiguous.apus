            | "<" selection ">"
            | "(" selection ")"
            
            
terminal    = identifier    [ "---" "(" < literal > ")" ]
            | literal
            | regex
            | epsilon | empty


epsilon     = "ε"
empty       = "\"\""

layout      = [ ">>|" | "|<<" | "<n>" | "<s>" | ">n<" | ">s<" ]

mode        = { "===" name [ "<<<" ] [ ">>>" name ] }
name        = literal | identifier
