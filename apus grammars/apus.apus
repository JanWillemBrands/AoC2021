whitespace  : /\s+/ .
comment     : /\/\/.*/ .

identifier  - /[_\p{XID_Start}][-\p{XID_Continue}]*/ .
literal     - /\"(?:[^\"\\]|\\.)+\"/ .
regex       - /\/(?!\*)(?:[^\/\\]|\\.)+\// .

action      : /'(?:[^'\\]|\\.)*'/ .
pragma      - /@\p{XID_Start}\p{XID_Continue}*/ .
message     - /\^\^\^(?:(?s).*?)(?=\^\^\^|$)/ .

grammar     = < production > { message } .
              
production  = [ pragma ] identifier
                ( ":" ( regex | literal ) "." [ follow ]
                | "-" ( regex | literal ) "." [ follow ]
                | "-:" selection "."
                | "=" selection "."
                ) .

selection   = sequence { "|" sequence } .

sequence    = < factor [ "?" | "*" | "+" ] | layout > .

factor      = terminal
            | "[" selection "]"
            | "{" selection "}"
            | "<" selection ">"
            | "(" selection ")"
            .

terminal    = identifier    [ "---" "(" < literal > ")" ]
            | literal
            | regex
            | epsilon | empty
            .

epsilon     = "ε" .
empty       = "\"\"" .

layout      = ">>|" | "|<<" | "<n>" | "<s>" | ">n<" | ">s<" .

follow      = ( "<+<" | "<-<" | ">+>" | ">->" ) "(" < literal > ")" .


