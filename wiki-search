#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
DB_PATH="${ROOT_DIR}/wiki/index.db"

if [ $# -lt 1 ]; then
  echo "Usage: ./wiki-search \"query\" [topN]"
  exit 1
fi

QUERY="$1"
TOP="${2:-8}"

python3 "${ROOT_DIR}/tools/wiki/query_wiki.py" "${QUERY}" --db "${DB_PATH}" --top "${TOP}"
