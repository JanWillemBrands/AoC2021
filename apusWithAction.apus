                terminal                @node = terminal()@
                | "[" selection         @node = GrammarNode(.OPT(body: node))@
                  "]"
                | "{" selection         @node = GrammarNode(.REP(body: node))@
                  "}"
                | "<" selection         @node = GrammarNode(.SEQ(head: node, tail: GrammarNode(.REP(body: node))))@
